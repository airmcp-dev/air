{
  "name": "air",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "description": "Build, run, and manage MCP servers",
  "author": {
    "name": "CodePedia Labs",
    "url": "https://labs.codepedia.kr"
  },
  "license": "Apache-2.0",
  "homepage": "https://airmcp.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/airmcp-dev/air"
  },
  "bugs": {
    "url": "https://github.com/airmcp-dev/air/issues"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/airmcp-dev"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "tools",
    "typescript",
